# Resend — https://resend.com
# Copy this file to `.env.local` and fill in the values.

# Required: your Resend API key (https://resend.com/api-keys).
RESEND_API_KEY=

# Required: the audience (subscriber list) to add signups to.
# Create one at https://resend.com/audiences and copy its Audience ID.
# Adding contacts needs no verified domain and has no send limits.
RESEND_AUDIENCE_ID=

# Optional: email address notified on each new subscriber. Leave unset to
# disable notifications. In Resend test mode this must be your account email;
# verify a domain to notify any address (and set RESEND_FROM accordingly).
RESEND_NOTIFY_TO=
# RESEND_FROM="Foxy <onboarding@resend.dev>"
