# Resend email API — https://resend.com/api-keys
# Copy this file to `.env.local` and fill in your key.

# Required: your Resend API key.
RESEND_API_KEY=

# Optional: verified sender. Defaults to Resend's test sender.
# RESEND_FROM="Foxy <onboarding@resend.dev>"

# Optional: where new-subscriber notifications are delivered.
# RESEND_TO=tabaexperience@gmail.com
